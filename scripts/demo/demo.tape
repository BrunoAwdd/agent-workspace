Output demo.gif

Require python3

Set Shell "bash"
Set FontSize 18
Set FontFamily "JetBrains Mono"
Set Width 1100
Set Height 600
Set TypingSpeed 50ms
Set Theme "TokyoNight"
Set Padding 40
Set Margin 20

Type "# Let's watch 3 agents coordinate using Agent Workspace"
Sleep 1s
Enter
Enter

Type "python3 demo.py"
Sleep 1s
Enter

# The python script takes roughly 20s to execute
Sleep 22s
